# =============================================================================
# datahub-service 环境变量示例
# 复制此文件为 .env 并填写真实配置
# =============================================================================

# --- 服务基础配置 ---
PROJECT_NAME=Datahub Service
ENVIRONMENT=development          # development | production

# --- 数据库 ---
# asyncpg 驱动，URL 格式：postgresql+asyncpg://user:pass@host:port/dbname
DATABASE_URL=postgresql+asyncpg://nexus_admin:changeme@localhost:5432/nexuskit_datahub
DEBUG=false

# --- 阿里云 OSS ---
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
# 地域 Endpoint（不含 bucket 名，不含 https://）
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# JSON 映射：app_code → bucket 名，必须包含 "default" 兜底
OSS_BUCKET_MAP={"default":"bucket-default","diagnosis":"bucket-diagnosis"}

# --- NexusKit 服务间鉴权 ---
# 此服务向 NexusKit 发起内部调用时使用
NEXUSKIT_URL=http://nexuskit-service:5000
NEXUSKIT_APP_CODE=datahub
NEXUSKIT_APP_SECRET=replace-with-actual-secret
