# ============================================
# NexusKit 全局环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=nexus_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=nexuskit_auth
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Gateway (Node.js) ---
GATEWAY_PORT=8000
GATEWAY_JWT_SECRET=change_me_in_production
GATEWAY_INTERNAL_SECRET=change_me_in_production
GATEWAY_UPSTREAM=http://127.0.0.1:5000
GATEWAY_REDIS_URL=redis://127.0.0.1:6379

# --- Services (Python/FastAPI) ---
SERVICE_PORT=5000
DATABASE_URL=postgresql+asyncpg://nexus_admin:change_me_in_production@127.0.0.1:5432/nexuskit_auth
REDIS_URL=redis://127.0.0.1:6379/0
SECRET_KEY=change_me_in_production
ALGORITHM=HS256
REFRESH_SECRET_KEY=change_me_in_production
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_SECRET=change_me_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
