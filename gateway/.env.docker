# ============================================
# NexusKit Gateway 环境变量
# ============================================

# --- 服务端口 ---
PORT=8000

# --- JWT 密钥 (必须与 services 中的 SECRET_KEY 一致) ---
JWT_SECRET=change_me_to_a_random_string

# --- 网关内部通信密钥 (必须与 services 中的 INTERNAL_SECRET 一致) ---
INTERNAL_SECRET=change_me_internal_secret

# --- 上游服务地址 ---
UPSTREAM_URL=http://api:5000

# --- Redis 地址（仅用于 AT 黑名单检查） ---
REDIS_URL=redis://redis:6379
